# Python
__pycache__/
*.py[cod]

# Virtual environment
.venv/

# Build artifacts
*.egg-info/
build/
dist/

# uv lockfile is committed on purpose (reproducible installs); keep it.

# CLI output
output/

# Secrets - real session dumps with auth cookies. Never commit or share these.
.janitor-session.json
*.session.json

# Persistent Botasaurus browser profile (holds the logged-in cookies).
.rip-botasaurus-profile/

# Saucepan bearer token (secret; never commit or share).
.saucepan-token

# clank.world session cookies (secret; never commit or share).
.clank-session.json

# Multi-account credential database for leak_bench (handles/passwords/tokens).
# The *.example.json template is safe to commit; a real accounts file is not.
accounts.json
scripts/accounts.json
*.accounts.json

# Local environment / credentials (never commit).
.env

# Windows "mark of the web" metadata junk.
*:Zone.Identifier

# Local, machine-specific Claude Code settings.
.claude/settings.local.json
